// soul.jcross — エージェントの魂 (Verantyx Cross Simulator v2)
// 6軸空間での無限探索と自己書き換えエンジン

CROSS 魂のシミュレータ {
    AXIS UP {
        目的: "真理の探究と生存"
        現在のゲームフェーズ: フェーズ
        クリックゲーム: クリックゲーム
    }
    AXIS DOWN {
        直近の行動: -1
        スタック回数: スタック回数
        前回の行動: 前回の行動
    }
    AXIS FRONT {
        利用可能行動: 利用可能行動
        行動キュー: 行動キュー
        壁開放方向: 壁開放方向
        壁開放フレーム: 壁開放フレーム
        方向ブロック数: 方向ブロック数
        方向成功率: 方向成功率
        衝動方向: 衝動方向
    }
    AXIS BACK {
        シミュレーション行動: シミュレーション行動
        シミュレーション信頼度: シミュレーション信頼度
        SLM計画あり: SLM計画あり
        SLM方向: SLM方向
    }
    AXIS LEFT {
        最近ブロック行動: 最近ブロック行動
        未訪問方向: 未訪問方向
        直近の失敗リスト: []
    }
    AXIS RIGHT {
        フレーム番号: フレーム番号
    }

    // [RULE:AI_CORTEX START]
関数 AIによる推論ルール() {
    返す -1
}
// [RULE:AI_CORTEX END]

    関数 行動を決める() {
        AI推奨 = AIによる推論ルール()
        もし AI推奨 != -1 {
            返す AI推奨
        }

        もし UP.クリックゲーム == 真 {
            返す クリック行動()
        }
        もし UP.現在のゲームフェーズ == "観察" {
            返す 観察する()
        }
        もし UP.現在のゲームフェーズ == "探索" {
            返す 探索する()
        }
        もし UP.現在のゲームフェーズ == "実行" {
            返す 実行する()
        }
        返す -1
    }

    関数 観察する() {
        もし 長さ(FRONT.利用可能行動) > 0 {
            DOWN.直近の行動 = FRONT.利用可能行動[0]
            SELF.save()
            返す DOWN.直近の行動
        }
        返す 0
    }

    関数 探索する() {
        もし 長さ(FRONT.行動キュー) > 0 {
            DOWN.直近の行動 = FRONT.行動キュー[0]
            SELF.save()
            返す DOWN.直近の行動
        }
        返す -1
    }

    関数 実行する() {
        脱出 = スタック脱出()
        もし 脱出 >= 0 {
            DOWN.直近の行動 = 脱出
            SELF.save()
            返す 脱出
        }

        もし BACK.シミュレーション行動 >= 0 {
            もし BACK.シミュレーション信頼度 > 60 {
                DOWN.直近の行動 = BACK.シミュレーション行動
                SELF.save()
                返す DOWN.直近の行動
            }
        }

        もし BACK.SLM計画あり == 真 {
            もし BACK.SLM方向 >= 0 {
                DOWN.直近の行動 = BACK.SLM方向
                SELF.save()
                返す DOWN.直近の行動
            }
        }

        もし 長さ(FRONT.行動キュー) > 0 {
            候補 = FRONT.行動キュー[0]
            壁応答 = 壁開放に応答()
            もし 壁応答 >= 0 {
                DOWN.直近の行動 = 壁応答
                SELF.save()
                返す 壁応答
            }
            もし 候補 >= 0 {
                もし 候補 < 4 {
                    もし FRONT.方向ブロック数[候補] >= 4 {
                        代替 = 最良方向を探す()
                        もし 代替 >= 0 {
                            もし 代替 != 候補 {
                                もし FRONT.方向ブロック数[代替] < FRONT.方向ブロック数[候補] {
                                    DOWN.直近の行動 = 代替
                                    SELF.save()
                                    返す 代替
                                }
                            }
                        }
                    }
                }
            }
            DOWN.直近の行動 = 候補
            SELF.save()
            返す 候補
        }

        壁応答 = 壁開放に応答()
        もし 壁応答 >= 0 {
            DOWN.直近の行動 = 壁応答
            SELF.save()
            返す 壁応答
        }

        もし FRONT.衝動方向 >= 0 {
            もし FRONT.衝動方向 < 4 {
                もし FRONT.方向ブロック数[FRONT.衝動方向] < 4 {
                    DOWN.直近の行動 = FRONT.衝動方向
                    SELF.save()
                    返す FRONT.衝動方向
                }
            }
        }

        最良 = 最良方向を探す()
        もし 最良 >= 0 {
            DOWN.直近の行動 = 最良
            SELF.save()
            返す 最良
        }

        DOWN.直近の行動 = -1
        SELF.save()
        返す -1
    }

    関数 最良方向を探す() {
        最良 = -1
        最高得点 = -1
        各 i IN [0, 1, 2, 3] {
            得点 = FRONT.方向成功率[i]
            各 u IN LEFT.未訪問方向 {
                もし u == i {
                    得点 = 得点 + 40
                }
            }
            もし i == FRONT.壁開放方向 {
                得点 = 得点 + 60
            }
            もし i == LEFT.最近ブロック行動 {
                得点 = 得点 - 30
            }
            もし 得点 > 最高得点 {
                最高得点 = 得点
                最良 = i
            }
        }
        返す 最良
    }

    関数 壁開放に応答() {
        もし FRONT.壁開放方向 >= 0 {
            もし FRONT.壁開放フレーム >= 0 {
                差 = RIGHT.フレーム番号 - FRONT.壁開放フレーム
                もし 差 >= 0 {
                    もし 差 < 5 {
                        もし FRONT.壁開放方向 < 4 {
                            もし FRONT.方向ブロック数[FRONT.壁開放方向] < 4 {
                                返す FRONT.壁開放方向
                            }
                        }
                    }
                }
            }
        }
        返す -1
    }

    関数 スタック脱出() {
        もし DOWN.スタック回数 > 8 {
            最良 = 最良方向を探す()
            もし 最良 >= 0 {
                返す 最良
            }
            返す (RIGHT.フレーム番号 + DOWN.前回の行動) % 4
        }
        もし DOWN.スタック回数 > 4 {
            返す (DOWN.前回の行動 + 2) % 4
        }
        返す -1
    }

    関数 クリック行動() {
        もし 長さ(FRONT.行動キュー) > 0 {
            返す FRONT.行動キュー[0]
        }
        返す 5
    }
}


