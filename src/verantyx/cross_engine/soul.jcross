// [RULE:因果_5 START]
// 因果等価式: 右 × wall × 色0
//   $= blocked (観測3回)
関数 回避_5(方向, 前方色) {
  もし 方向 == 3 {
    もし 前方色 == 0 {
      返す 1
    }
  }
  返す -1
}
// [RULE:因果_5 END]

