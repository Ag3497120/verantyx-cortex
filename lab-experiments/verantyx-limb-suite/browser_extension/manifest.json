{
  "manifest_version": 3,
  "name": "Verantyx Eye: Native Bridge",
  "version": "1.1",
  "description": "Verantyx専用のネイティブ・ブラウザ内神経接続ブリッジ",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "*://gemini.google.com/*",
    "*://*.google.com/*",
    "http://127.0.0.1:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://gemini.google.com/*",
        "*://*.google.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
